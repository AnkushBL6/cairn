# dependencies
node_modules/
.pnpm-store/

# build output
dist/
*.tsbuildinfo
packages/*/dist/

# next.js
website/.next/
website/out/
website/node_modules/

# test / coverage
coverage/

# logs
*.log
npm-debug.log*
pnpm-debug.log*

# os / editor
.DS_Store
.idea/
.vscode/*
!.vscode/extensions.json

# browser-QA scratch output (Playwright MCP)
.playwright-mcp/

# env
.env
.env.*
!.env.example

# NOTE: .cairn/ is intentionally NOT ignored — it is the project "brain"
# and is committed to git so any fresh session can reload full context.
# Only ignore ephemeral studio runtime state:
.cairn/.runtime/
