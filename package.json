{
  "name": "cairn-monorepo",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Cairn — the skillpack that gives your AI agent continuity. Idea → graph-persisted design → test-first build.",
  "packageManager": "pnpm@11.0.3",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "pnpm -r --filter \"./packages/*\" build",
    "typecheck": "pnpm -r --filter \"./packages/*\" typecheck",
    "test": "vitest run",
    "test:watch": "vitest",
    "coverage": "vitest run --coverage",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write ."
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/node": "^22.10.5",
    "@vitest/coverage-v8": "^3.2.0",
    "jsdom": "^25.0.1",
    "typescript": "^5.7.3",
    "vitest": "^3.2.0"
  }
}
