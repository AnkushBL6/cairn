{
  "version": 1,
  "nodes": [
    {
      "id": "goal--ai-agents-that-never-start-from-zero",
      "type": "goal",
      "title": "AI agents that never start from zero",
      "body": "Capture a project's intent as a typed knowledge graph committed to .cairn/, so any fresh, context-free session resumes with full understanding instead of re-interrogating the user.",
      "status": "accepted",
      "tags": [],
      "createdInSession": "cli",
      "createdAt": "2026-06-20T16:52:01.279Z"
    },
    {
      "id": "requirement--persist-intent-as-a-typed-knowledge-graph",
      "type": "requirement",
      "title": "Persist intent as a typed knowledge graph",
      "body": "Brainstorm output becomes typed nodes and edges in .cairn/graph.json, versioned in git right beside the code.",
      "status": "accepted",
      "tags": [],
      "createdInSession": "cli",
      "createdAt": "2026-06-20T16:52:01.280Z"
    },
    {
      "id": "requirement--resume-full-context-in-a-fresh-session",
      "type": "requirement",
      "title": "Resume full context in a fresh session",
      "body": "A context-free agent reads a stable resume brief: goals, accepted decisions, components with their dependencies, open questions, and suggested next actions.",
      "status": "accepted",
      "tags": [],
      "createdInSession": "cli",
      "createdAt": "2026-06-20T16:52:01.280Z"
    },
    {
      "id": "requirement--guarantee-test-first-builds",
      "type": "requirement",
      "title": "Guarantee test-first builds",
      "body": "Every unit starts from a provably real red — a behavioral assertion that exercised the unit — never a missing-symbol error mistaken for a failing test.",
      "status": "accepted",
      "tags": [],
      "createdInSession": "cli",
      "createdAt": "2026-06-20T16:52:01.280Z"
    },
    {
      "id": "requirement--install-missing-capabilities-on-demand",
      "type": "requirement",
      "title": "Install missing capabilities on demand",
      "body": "When a request needs a capability Cairn doesn't ship, discover and install the right skill from the open agent-skills ecosystem after checking the built-ins first.",
      "status": "accepted",
      "tags": [],
      "createdInSession": "cli",
      "createdAt": "2026-06-20T16:52:01.280Z"
    },
    {
      "id": "decision--pnpm-monorepo-typescript-strict-esm-vitest-biome",
      "type": "decision",
      "title": "pnpm monorepo, TypeScript strict ESM, Vitest + Biome",
      "body": "One workspace, three packages, strict types, ESM only, no legacy or back-compat shims.",
      "status": "accepted",
      "tags": [],
      "createdInSession": "cli",
      "createdAt": "2026-06-20T16:52:01.280Z"
    },
    {
      "id": "decision--keep-the-core-engine-pure-and-deterministic",
      "type": "decision",
      "title": "Keep the core engine pure and deterministic",
      "body": "The clock and session id are injected, so identical operations always produce an identical committed graph across machines.",
      "status": "accepted",
      "tags": [],
      "createdInSession": "cli",
      "createdAt": "2026-06-20T16:52:01.280Z"
    },
    {
      "id": "decision--classify-a-real-red-vs-a-missing-symbol",
      "type": "decision",
      "title": "Classify a real red vs a missing-symbol",
      "body": "Precedence is collection -> missing-symbol -> assertion -> pass -> unknown; only a clean assertion counts as a legitimate red to build against.",
      "status": "accepted",
      "tags": [],
      "createdInSession": "cli",
      "createdAt": "2026-06-20T16:52:01.280Z"
    },
    {
      "id": "decision--studio-is-a-zero-dependency-node-server-self-contained-html",
      "type": "decision",
      "title": "Studio is a zero-dependency Node server + self-contained HTML wizard",
      "body": "A CSRF-guarded live browser session for brainstorming, with a static wizard fallback for headless environments.",
      "status": "accepted",
      "tags": [],
      "createdInSession": "cli",
      "createdAt": "2026-06-20T16:52:01.280Z"
    },
    {
      "id": "decision--ship-skills-on-the-vercel-npx-skills-open-standard",
      "type": "decision",
      "title": "Ship skills on the Vercel `npx skills` open standard",
      "body": "Install with `npx skills add AnkushBL6/cairn@<skill>`; works across Claude Code, Cursor, Copilot and 18+ agents.",
      "status": "accepted",
      "tags": [],
      "createdInSession": "cli",
      "createdAt": "2026-06-20T16:52:01.280Z"
    },
    {
      "id": "decision--enforce-a-typed-edge-legality-table",
      "type": "decision",
      "title": "Enforce a typed edge-legality table",
      "body": "An edge is only allowed when its (type, from-type, to-type) triple is semantically valid, so the graph can never encode a nonsensical relationship.",
      "status": "accepted",
      "tags": [],
      "createdInSession": "cli",
      "createdAt": "2026-06-20T16:52:01.280Z"
    },
    {
      "id": "component--cairn-core",
      "type": "component",
      "title": "@cairn/core",
      "body": "The pure graph engine: typed nodes/edges, integrity invariants, the Mermaid + design-doc renderers, the resume brief, and the test-failure classifier. Built 100% test-first.",
      "status": "done",
      "tags": [],
      "createdInSession": "cli",
      "createdAt": "2026-06-20T16:52:01.280Z"
    },
    {
      "id": "component--cairn-studio",
      "type": "component",
      "title": "@cairn/studio",
      "body": "Zero-dependency Node server plus a world-class self-contained HTML brainstorming wizard, with a static fallback.",
      "status": "done",
      "tags": [],
      "createdInSession": "cli",
      "createdAt": "2026-06-20T16:52:01.280Z"
    },
    {
      "id": "component--cairn-cli",
      "type": "component",
      "title": "@cairn/cli",
      "body": "The `cairn` command that wires the engine and studio to disk: init, studio, ingest, graph, resume, classify.",
      "status": "done",
      "tags": [],
      "createdInSession": "cli",
      "createdAt": "2026-06-20T16:52:01.280Z"
    },
    {
      "id": "component--cairn-skillpack-six-skills",
      "type": "component",
      "title": "Cairn skillpack (six skills)",
      "body": "brainstorm, resume, tdd, frontend, backend, router — each reads the project graph instead of re-interrogating the user.",
      "status": "done",
      "tags": [],
      "createdInSession": "cli",
      "createdAt": "2026-06-20T16:52:01.280Z"
    },
    {
      "id": "component--marketing-website-docs",
      "type": "component",
      "title": "Marketing website + docs",
      "body": "Production-grade Next.js site (standalone, Lighthouse 99/100/100/100) with docs pages and an interactive graph playground.",
      "status": "done",
      "tags": [],
      "createdInSession": "cli",
      "createdAt": "2026-06-20T16:52:01.280Z"
    },
    {
      "id": "component--cairn-tdd-guard-github-action",
      "type": "component",
      "title": "Cairn TDD Guard GitHub Action",
      "body": "A reusable composite GitHub Action wrapping the classifier so any repo enforces guaranteed-TDD on PRs. Ships a zero-dependency vendored classifier kept in lockstep with @cairn/core by a parity test.",
      "status": "done",
      "tags": [],
      "createdInSession": "cli",
      "createdAt": "2026-06-20T16:52:01.280Z"
    },
    {
      "id": "constraint--node-22-esm-only-no-legacy-code",
      "type": "constraint",
      "title": "Node >= 22, ESM only, no legacy code",
      "body": "Only clean, current code ships — no back-compat shims, no dead paths (noUnusedLocals/Parameters on).",
      "status": "accepted",
      "tags": [],
      "createdInSession": "cli",
      "createdAt": "2026-06-20T16:52:01.280Z"
    },
    {
      "id": "constraint--no-filesystem-or-ambient-i-o-in-cairn-core",
      "type": "constraint",
      "title": "No filesystem or ambient I/O in @cairn/core",
      "body": "All disk I/O lives in the CLI store, so the engine stays pure, deterministic, and trivially testable.",
      "status": "accepted",
      "tags": [],
      "createdInSession": "cli",
      "createdAt": "2026-06-20T16:52:01.280Z"
    },
    {
      "id": "constraint--vercel-cli-must-be-54",
      "type": "constraint",
      "title": "Vercel CLI must be >= 54",
      "body": "The old 39.x used a discontinued login flow that just opened a changelog page; deploy with a modern CLI.",
      "status": "accepted",
      "tags": [],
      "createdInSession": "cli",
      "createdAt": "2026-06-20T16:52:01.280Z"
    },
    {
      "id": "question--publish-cairn-to-npm",
      "type": "question",
      "title": "Publish @cairn/* to npm?",
      "body": "Today install is only `npx skills add`; npm publishing would enable `npm i @cairn/core` plus a tagged release pipeline (Changesets).",
      "status": "open",
      "tags": [],
      "createdInSession": "cli",
      "createdAt": "2026-06-20T16:52:01.280Z"
    },
    {
      "id": "question--host-the-studio-brainstorming-wizard-online",
      "type": "question",
      "title": "Host the studio brainstorming wizard online?",
      "body": "A hosted playground would let people try the typed-graph model without installing anything locally.",
      "status": "open",
      "tags": [],
      "createdInSession": "cli",
      "createdAt": "2026-06-20T16:52:01.280Z"
    },
    {
      "id": "risk--classifier-drift-between-core-and-the-action",
      "type": "risk",
      "title": "Classifier drift between core and the Action",
      "body": "The zero-install Action vendors the classifier; without a parity test it can silently diverge from @cairn/core.",
      "status": "open",
      "tags": [],
      "createdInSession": "cli",
      "createdAt": "2026-06-20T16:52:01.280Z"
    },
    {
      "id": "risk--graph-schema-migrations",
      "type": "risk",
      "title": "Graph schema migrations",
      "body": "GraphDoc is version 1; evolving the node/edge vocabulary will need a migration path so old committed brains still load.",
      "status": "open",
      "tags": [],
      "createdInSession": "cli",
      "createdAt": "2026-06-20T16:52:01.280Z"
    },
    {
      "id": "test--classify-failure-unit-suite",
      "type": "test",
      "title": "classify-failure unit suite",
      "body": "Locks the precedence and the real-red boundary that the whole guaranteed-TDD promise rests on.",
      "status": "done",
      "tags": [],
      "createdInSession": "cli",
      "createdAt": "2026-06-20T16:52:01.280Z"
    },
    {
      "id": "test--action-core-classifier-parity-test",
      "type": "test",
      "title": "Action <-> core classifier parity test",
      "body": "Feeds a shared corpus to both the Action's vendored classifier and @cairn/core and asserts identical verdicts — kills drift.",
      "status": "done",
      "tags": [],
      "createdInSession": "cli",
      "createdAt": "2026-06-20T16:52:01.280Z"
    },
    {
      "id": "artifact--the-cairn-project-brain-graph-json",
      "type": "artifact",
      "title": "The .cairn/ project brain (graph.json)",
      "body": "This very file's output: the committed knowledge graph a fresh session reloads.",
      "status": "done",
      "tags": [],
      "createdInSession": "cli",
      "createdAt": "2026-06-20T16:52:01.280Z"
    },
    {
      "id": "artifact--generated-design-md-graph-mmd",
      "type": "artifact",
      "title": "Generated design.md + graph.mmd",
      "body": "Human-readable narrative and Mermaid diagram, regenerated from the graph on every save.",
      "status": "done",
      "tags": [],
      "createdInSession": "cli",
      "createdAt": "2026-06-20T16:52:01.280Z"
    }
